#!/usr/bin/env bash

get_docker_port () {
  docker compose port $1 $2 | cut -d ":" -f2
}


docker compose down --remove-orphans -v
docker compose up -d

# ── DynamoDB ──────────────────────────────────────────────────────────────────

DYNAMO_ENDPOINT="http://localhost:$(get_docker_port dynamodb-local 8000)"

echo "Waiting for DynamoDB Local..."
until aws dynamodb list-tables --endpoint-url "$DYNAMO_ENDPOINT" --no-cli-pager --no-paginate &>/dev/null; do
  sleep 1
done

aws dynamodb create-table \
  --endpoint-url "$DYNAMO_ENDPOINT" \
  --table-name todos \
  --key-schema AttributeName=id,KeyType=HASH \
  --attribute-definitions AttributeName=id,AttributeType=S AttributeName=user_id,AttributeType=S \
  --billing-mode PAY_PER_REQUEST \
  --global-secondary-indexes '[{"IndexName":"user_id-index","KeySchema":[{"AttributeName":"user_id","KeyType":"HASH"}],"Projection":{"ProjectionType":"ALL"}}]' \
  --no-cli-pager

# ── Keycloak ──────────────────────────────────────────────────────────────────

KEYCLOAK_URL="http://localhost:$(get_docker_port keycloak 8080)"
KEYCLOAK_REALM="todont"
KEYCLOAK_CLIENT_ID="todont-api"

echo "Waiting for Keycloak..."
until curl -sf "$KEYCLOAK_URL/realms/master" &>/dev/null; do
  sleep 2
done

ADMIN_TOKEN=$(curl -sf -X POST "$KEYCLOAK_URL/realms/master/protocol/openid-connect/token" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "username=admin&password=admin&grant_type=password&client_id=admin-cli" \
  | jq -r '.access_token')

curl -sf -X POST "$KEYCLOAK_URL/admin/realms" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{\"realm\": \"$KEYCLOAK_REALM\", \"enabled\": true}"

curl -sf -X POST "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{
    \"clientId\": \"$KEYCLOAK_CLIENT_ID\",
    \"enabled\": true,
    \"serviceAccountsEnabled\": true,
    \"publicClient\": false,
    \"protocol\": \"openid-connect\"
  }"

CLIENT_UUID=$(curl -sf "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients?clientId=$KEYCLOAK_CLIENT_ID" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  | jq -r '.[0].id')

# Add audience mapper so the client ID appears in the token's aud claim
curl -sf -X POST "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients/$CLIENT_UUID/protocol-mappers/models" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{
    \"name\": \"audience-mapper\",
    \"protocol\": \"openid-connect\",
    \"protocolMapper\": \"oidc-audience-mapper\",
    \"config\": {
      \"included.client.audience\": \"$KEYCLOAK_CLIENT_ID\",
      \"id.token.claim\": \"false\",
      \"access.token.claim\": \"true\"
    }
  }"

KEYCLOAK_CLIENT_SECRET=$(curl -sf "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients/$CLIENT_UUID/client-secret" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  | jq -r '.value')

# ── Second client for two-user integration tests ───────────────────────────────

KEYCLOAK_CLIENT_ID_B="todont-api-user-b"

curl -sf -X POST "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{
    \"clientId\": \"$KEYCLOAK_CLIENT_ID_B\",
    \"enabled\": true,
    \"serviceAccountsEnabled\": true,
    \"publicClient\": false,
    \"protocol\": \"openid-connect\"
  }"

CLIENT_B_UUID=$(curl -sf "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients?clientId=$KEYCLOAK_CLIENT_ID_B" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  | jq -r '.[0].id')

# Audience must match KEYCLOAK_CLIENT_ID so the app's JWT validation accepts it
curl -sf -X POST "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients/$CLIENT_B_UUID/protocol-mappers/models" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{
    \"name\": \"audience-mapper\",
    \"protocol\": \"openid-connect\",
    \"protocolMapper\": \"oidc-audience-mapper\",
    \"config\": {
      \"included.client.audience\": \"$KEYCLOAK_CLIENT_ID\",
      \"id.token.claim\": \"false\",
      \"access.token.claim\": \"true\"
    }
  }"

KEYCLOAK_CLIENT_SECRET_B=$(curl -sf "$KEYCLOAK_URL/admin/realms/$KEYCLOAK_REALM/clients/$CLIENT_B_UUID/client-secret" \
  -H "Authorization: Bearer $ADMIN_TOKEN" \
  | jq -r '.value')

# ── Write env file ─────────────────────────────────────────────────────────────

cat << EOF > bin/test_env
export AWS_ENDPOINT_URL_DYNAMODB=$DYNAMO_ENDPOINT
export KEYCLOAK_URL=$KEYCLOAK_URL
export KEYCLOAK_REALM=$KEYCLOAK_REALM
export KEYCLOAK_CLIENT_ID=$KEYCLOAK_CLIENT_ID
export KEYCLOAK_CLIENT_SECRET=$KEYCLOAK_CLIENT_SECRET
export KEYCLOAK_CLIENT_ID_B=$KEYCLOAK_CLIENT_ID_B
export KEYCLOAK_CLIENT_SECRET_B=$KEYCLOAK_CLIENT_SECRET_B
EOF

echo "source bin/test_env"
